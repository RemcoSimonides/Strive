default_platform(:ios)

MAIN_APP_ID = "com.strive.journal"
SHARE_EXT_ID = "com.strive.journal.share"
TEAM_ID = "2Z8SN3C4MM"

platform :ios do
  desc "Fetch or create signing certificates and provisioning profiles via Match"
  lane :certificates do
    match(
      type: "appstore",
      app_identifier: [MAIN_APP_ID, SHARE_EXT_ID],
      readonly: is_ci,
    )
  end

  desc "Build a signed IPA"
  lane :build do
    certificates

    # Switch both targets to manual signing for CI builds
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: TEAM_ID,
      bundle_identifier: MAIN_APP_ID,
      profile_name: ENV["sigh_#{MAIN_APP_ID}_appstore_profile-name"],
      targets: ["App"],
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: TEAM_ID,
      bundle_identifier: SHARE_EXT_ID,
      profile_name: ENV["sigh_#{SHARE_EXT_ID}_appstore_profile-name"],
      targets: ["share"],
    )

    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      output_directory: "./build",
      output_name: "StriveJournal.ipa",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          MAIN_APP_ID => ENV["sigh_#{MAIN_APP_ID}_appstore_profile-name"],
          SHARE_EXT_ID => ENV["sigh_#{SHARE_EXT_ID}_appstore_profile-name"],
        }
      }
    )
  end

  desc "Deploy to TestFlight"
  lane :deploy_testflight do
    build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/StriveJournal.ipa",
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Deploy to App Store production"
  lane :deploy_production do
    build

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true,
    )

    upload_to_app_store(
      api_key: api_key,
      ipa: "./build/StriveJournal.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
    )
  end
end
